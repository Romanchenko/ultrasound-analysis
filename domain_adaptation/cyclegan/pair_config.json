{
    "dataset_a": {
        "adapter": "datasets_adapters.fetal_planes_db.fpd_dataset.FetalPlanesDBDataset",
        "params": {
            "root": "/path/to/fetal_planes_db"
        }
    },
    "dataset_b": {
        "adapter": "datasets_adapters.fetal_head_circ.fhc_dataset.FetalHeadCircDataset",
        "params": {
            "images_dir": "/path/to/fhc/training_set",
            "csv_file": "/path/to/fhc/training_set_pixel_size_and_HC.csv",
            "load_annotations": false
        }
    },
    "training": {
        "n_epochs": 200,
        "batch_size": 4,
        "image_size": 256,
        "input_channels": 1,
        "n_residual_blocks": 9,
        "lr_g": 0.0002,
        "lr_d": 0.0002,
        "lambda_cycle": 10.0,
        "lambda_identity": 0.5,
        "num_workers": 4,
        "visualize_every": 10
    },
    "checkpoint_dir": "./checkpoints/cyclegan",
    "output_dir": "./translated_images"
}



